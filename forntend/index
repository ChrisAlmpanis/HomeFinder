<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Sign In</title>
<link rel="stylesheet" href="shared.css"/>
<style>
body{background:none;display:block;min-height:100vh}
.login-wrap{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:
    linear-gradient(rgba(15,70,38,0.72),rgba(8,48,24,0.82)),
    url('https://images.unsplash.com/photo-1555993539-1732b0258235?auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;
  padding:24px;
}
.login-box{background:var(--w);width:100%;max-width:400px;border:1px solid var(--br)}
.login-header{background:var(--g);padding:24px;text-align:center;color:var(--w)}
.login-header h1{font-size:22px;font-weight:700;margin-bottom:4px}
.login-header p{font-size:13px;color:rgba(255,255,255,.7)}
.login-body{padding:28px}
</style>
</head>
<body>
<div class="toast" id="toast"></div>
<div class="login-wrap">
  <div class="login-box">
    <div class="login-header">
      <h1>Home Finder</h1>
      <p>Sign in to your account to continue</p>
    </div>
    <div class="login-body">
      <div class="emsg" id="lerr">Incorrect username or password.</div>
      <div class="fg"><label class="fl">Username or Email</label><input type="text" class="fi" id="lu" placeholder="you@email.com" autofocus/></div>
      <div class="fg"><label class="fl">Password</label><input type="password" class="fi" id="lp" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"/></div>
      <div style="text-align:right;margin-bottom:20px;margin-top:4px"><button class="lbtn" onclick="toast('Password reset link sent.')">Forgot password?</button></div>
      <button class="bfu bfu-g" onclick="doLogin()">Sign In</button>
      <div class="fdiv"><div class="fdl"></div><div class="fdt">or</div><div class="fdl"></div></div>
      <button class="bfu bfu-o" onclick="location.href='signup.html'">Create Account</button>
      <p style="font-size:11px;color:var(--li);margin-top:18px;text-align:center;line-height:1.8">
        Demo logins:<br>
        Seller: <strong style="color:var(--mu)">seller</strong> / <strong style="color:var(--mu)">pass123</strong><br>
        Buyer: <strong style="color:var(--mu)">buyer</strong> / <strong style="color:var(--mu)">buyer123</strong><br>
        Admin: <strong style="color:var(--mu)">admin</strong> / <strong style="color:var(--mu)">12345678</strong>
      </p>
    </div>
  </div>
</div>
<script>
function initData(){
  if(!sessionStorage.getItem('hf_ls')){
    sessionStorage.setItem('hf_ls',JSON.stringify([
      {id:1,price:"€485,000",raw:485000,address:"Kolonaki, Athens",city:"Kolonaki",type:"Apartment",beds:3,baths:2,sqft:"120 m²",desc:"Elegant three-bedroom apartment in prestigious Kolonaki. High ceilings, marble floors and a balcony with Acropolis views. Walking distance to top restaurants and boutiques.",seller:"Yannis Papadopoulos",si:"YP",img:"https://images.unsplash.com/photo-1560184897-ae75f418493e?auto=format&fit=crop&w=600&h=400"},
      {id:2,price:"€220,000",raw:220000,address:"Exarchia, Athens",city:"Exarchia",type:"Apartment",beds:2,baths:1,sqft:"75 m²",desc:"Charming two-bedroom apartment in vibrant Exarchia. Renovated kitchen, wooden floors and a sunny terrace. Near the National Archaeological Museum.",seller:"Maria Stavrou",si:"MS",img:"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=600&h=400"},
      {id:3,price:"€890,000",raw:890000,address:"Glyfada, Athens",city:"Glyfada",type:"House",beds:5,baths:3,sqft:"280 m²",desc:"Stunning seafront villa in Glyfada with private pool and direct beach access. Open-plan living, modern kitchen and panoramic sea views.",seller:"Yannis Papadopoulos",si:"YP",img:"https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=600&h=400"},
      {id:4,price:"€135,000",raw:135000,address:"Monastiraki, Athens",city:"Monastiraki",type:"Studio",beds:1,baths:1,sqft:"45 m²",desc:"Cozy studio steps from Monastiraki Square and the Acropolis. Ideal for investment or city living. Fully renovated with modern fixtures throughout.",seller:"Nikos Georgiou",si:"NG",img:"https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=600&h=400"},
      {id:5,price:"€620,000",raw:620000,address:"Kifisia, Athens",city:"Kifisia",type:"House",beds:4,baths:2,sqft:"200 m²",desc:"Beautiful four-bedroom house in leafy Kifisia. Large garden, private parking and tasteful interiors. One of Athens' most desirable northern suburbs.",seller:"Elena Nikolaou",si:"EN",img:"https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=600&h=400"},
      {id:6,price:"€310,000",raw:310000,address:"Plaka, Athens",city:"Plaka",type:"Apartment",beds:2,baths:1,sqft:"90 m²",desc:"Characterful apartment in historic Plaka with Parthenon views. Stone walls, original features and a rooftop terrace. A rare find in Athens' oldest neighbourhood.",seller:"Maria Stavrou",si:"MS",img:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=600&h=400"},
    ]));
  }
  if(!sessionStorage.getItem('hf_appts')){
    sessionStorage.setItem('hf_appts',JSON.stringify([
      {id:1,buyer:"James T.",buyerId:"buyer",seller:"Sarah M.",property:"Kolonaki Apt",date:"May 08",time:"10:00 AM",loc:"Athens",status:"confirmed"},
      {id:2,buyer:"Ana R.",buyerId:"",seller:"Maria S.",property:"Glyfada Villa",date:"May 14",time:"2:30 PM",loc:"Athens",status:"confirmed"},
      {id:3,buyer:"Nikos P.",buyerId:"",seller:"Sarah M.",property:"Plaka Apt",date:"May 20",time:"11:00 AM",loc:"Athens",status:"confirmed"},
      {id:4,buyer:"Lisa H.",buyerId:"",seller:"Sarah M.",property:"Monastiraki Studio",date:"May 22",time:"9:30 AM",loc:"Athens",status:"pending"},
    ]));
  }
  if(!sessionStorage.getItem('hf_booked')){
    sessionStorage.setItem('hf_booked',JSON.stringify([8,14,20,22]));
  }
}
function doLogin(){
  const u=document.getElementById('lu').value.trim();
  const p=document.getElementById('lp').value;
  document.getElementById('lerr').style.display='none';
  initData();
  const users={
    'admin':  {pass:'12345678',name:'Admin User',  role:'admin',  initials:'AU'},
    'seller': {pass:'pass123', name:'Sarah Mitchell',role:'seller',initials:'SM'},
    'buyer':  {pass:'buyer123',name:'James Thompson',role:'buyer', initials:'JT'},
  };
  const found=users[u.toLowerCase()];
  if(found && found.pass===p){
    sessionStorage.setItem('hf_user',JSON.stringify({name:found.name,role:found.role,initials:found.initials}));
    const dest={admin:'admin-dash.html',seller:'seller-dash.html',buyer:'buyer-dash.html'}[found.role]||'home.html';
    location.href=dest;
    return;
  }
  if(u && p.length>=6){
    initData();
    sessionStorage.setItem('hf_user',JSON.stringify({name:u,role:'buyer',initials:u.substring(0,2).toUpperCase()}));
    location.href='home.html';
    return;
  }
  document.getElementById('lerr').style.display='block';
}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
</script>
</body>
</html>