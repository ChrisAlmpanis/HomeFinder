<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="referrer" content="no-referrer"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Sign In</title>
<link rel="stylesheet" href="shared.css"/>
<style>
body{background:none;display:block;min-height:100vh}
.login-wrap{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:
    linear-gradient(rgba(15,70,38,0.72),rgba(8,48,24,0.82)),
    url('https://images.unsplash.com/photo-1555993539-1732b0258235?w=1920&h=1080&fit=crop&q=80') center/cover no-repeat;
  padding:24px;
}
.login-box{background:var(--w);width:100%;max-width:400px;border:1px solid var(--br)}
.login-header{background:var(--g);padding:24px;text-align:center;color:var(--w)}
.login-header h1{font-size:22px;font-weight:700;margin-bottom:4px}
.login-header p{font-size:13px;color:rgba(255,255,255,.7)}
.login-body{padding:28px}
</style>
</head>
<body>
<div class="toast" id="toast"></div>
<div class="login-wrap">
  <div class="login-box">
    <div class="login-header">
      <h1>Home Finder</h1>
      <p>Sign in to your account to continue</p>
    </div>
    <div class="login-body">
      <div class="emsg" id="lerr">Incorrect username or password.</div>
      <div class="fg"><label class="fl">Username or Email</label><input type="text" class="fi" id="lu" placeholder="you@email.com" autofocus/></div>
      <div class="fg"><label class="fl">Password</label><input type="password" class="fi" id="lp" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"/></div>
      <div style="text-align:right;margin-bottom:20px;margin-top:4px"><button class="lbtn" onclick="toast('Password reset link sent.')">Forgot password?</button></div>
      <button class="bfu bfu-g" onclick="doLogin()">Sign In</button>
      <div class="fdiv"><div class="fdl"></div><div class="fdt">or</div><div class="fdl"></div></div>
      <button class="bfu bfu-o" onclick="location.href='signup.html'">Create Account</button>
      <p style="font-size:11px;color:var(--li);margin-top:18px;text-align:center;line-height:1.8">
        Demo logins:<br>
        Seller: <strong style="color:var(--mu)">seller</strong> / <strong style="color:var(--mu)">pass123</strong><br>
        Buyer: <strong style="color:var(--mu)">buyer</strong> / <strong style="color:var(--mu)">buyer123</strong><br>
        Admin: <strong style="color:var(--mu)">admin</strong> / <strong style="color:var(--mu)">12345678</strong>
      </p>
    </div>
  </div>
</div>
<script>
function initData(){
  // Version bump clears old cached data with wrong images
  if(sessionStorage.getItem('hf_ver')!=='v4'){sessionStorage.clear();sessionStorage.setItem('hf_ver','v4');}
  if(!sessionStorage.getItem('hf_ls')){
        sessionStorage.setItem('hf_ls',JSON.stringify([
      {id:1,  price:"€485,000",raw:485000, address:"Kolonaki, Athens",    city:"Kolonaki",    type:"House",      beds:3,baths:2,sqft:"145 m²",listingMode:"buy",  addedDaysAgo:3,  desc:"Refined three-bedroom house in prestigious Kolonaki. High ceilings, oak floors and a private terrace with Acropolis views. Minutes from top restaurants and boutiques.",     seller:"Yannis Papadopoulos",si:"YP",img:"https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&h=400&fit=crop&q=80"},
      {id:2,  price:"€280,000",raw:280000, address:"Exarchia, Athens",    city:"Exarchia",    type:"Apartment",  beds:2,baths:1,sqft:"78 m²", listingMode:"buy",  addedDaysAgo:5,  desc:"Bright two-bedroom apartment in vibrant Exarchia. Renovated kitchen, wooden floors and a sunny balcony. Near the National Archaeological Museum and Strefi Hill.",          seller:"Maria Stavrou",     si:"MS",img:"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=600&h=400&fit=crop&q=80"},
      {id:3,  price:"€890,000",raw:890000, address:"Glyfada, Athens",     city:"Glyfada",     type:"House",      beds:5,baths:3,sqft:"280 m²",listingMode:"buy",  addedDaysAgo:12, desc:"Stunning five-bedroom seafront villa in Glyfada with private pool and direct beach access. Open-plan living, modern kitchen and panoramic Saronic Gulf views.",              seller:"Yannis Papadopoulos",si:"YP",img:"https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=600&h=400&fit=crop&q=80"},
      {id:4,  price:"€155,000",raw:155000, address:"Monastiraki, Athens", city:"Monastiraki", type:"Studio",     beds:1,baths:1,sqft:"42 m²", listingMode:"buy",  addedDaysAgo:7,  desc:"Compact studio steps from Monastiraki Square and the Acropolis. Fully renovated with modern fixtures, built-in storage and a private entrance. Perfect for investment.",     seller:"Nikos Georgiou",    si:"NG",img:"https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=600&h=400&fit=crop&q=80"},
      {id:5,  price:"€620,000",raw:620000, address:"Kifisia, Athens",     city:"Kifisia",     type:"House",      beds:4,baths:2,sqft:"200 m²",listingMode:"buy",  addedDaysAgo:45, desc:"Beautiful four-bedroom house in leafy Kifisia. Large private garden, off-street parking and tasteful interiors. One of Athens most desirable northern suburbs.",             seller:"Elena Nikolaou",    si:"EN",img:"https://images.unsplash.com/photo-1583608205776-bfd35f0d9f83?w=600&h=400&fit=crop&q=80"},
      {id:6,  price:"€350,000",raw:350000, address:"Plaka, Athens",       city:"Plaka",       type:"Apartment",  beds:2,baths:1,sqft:"88 m²", listingMode:"buy",  addedDaysAgo:20, desc:"Characterful apartment in historic Plaka with Parthenon views from the rooftop terrace. Stone walls, original features and updated fixtures throughout.",                    seller:"Maria Stavrou",     si:"MS",img:"https://images.unsplash.com/photo-1484154218962-a197022b5858?w=600&h=400&fit=crop&q=80"},
      {id:7,  price:"€550,000",raw:550000, address:"Psychiko, Athens",    city:"Psychiko",    type:"House",      beds:4,baths:3,sqft:"210 m²",listingMode:"buy",  addedDaysAgo:60, desc:"Elegant villa in upscale Psychiko. Landscaped garden, pool, double garage. Classic architecture with fully modernised interiors throughout.",                               seller:"Yannis Papadopoulos",si:"YP",img:"https://images.unsplash.com/photo-1580587771525-78b9dba3b914?w=600&h=400&fit=crop&q=80"},
      {id:8,  price:"€820/mo",  raw:1200,  address:"Piraeus, Athens",     city:"Piraeus",     type:"Apartment",  beds:2,baths:1,sqft:"65 m²", listingMode:"rent", addedDaysAgo:15, desc:"Well-maintained two-bedroom apartment near Piraeus port. Modern kitchen, tiled floors and a balcony with sea glimpses. Excellent transport links to central Athens.",        seller:"Nikos Georgiou",    si:"NG",img:"data:image/jpeg;base64,"},
      {id:9,  price:"€730,000",raw:730000, address:"Vouliagmeni, Athens", city:"Vouliagmeni", type:"House",      beds:5,baths:4,sqft:"300 m²",listingMode:"buy",  addedDaysAgo:90, desc:"Luxury five-bedroom villa in coastal Vouliagmeni with private pool and direct sea access. High-end finishes, open-plan kitchen and extensive landscaped grounds.",           seller:"Elena Nikolaou",    si:"EN",img:"https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&h=400&fit=crop&q=80"},
      {id:10, price:"€650/mo",  raw:800,   address:"Nea Smyrni, Athens",  city:"Nea Smyrni",  type:"Studio",     beds:1,baths:1,sqft:"38 m²", listingMode:"rent", addedDaysAgo:35, desc:"Cosy studio apartment in Nea Smyrni with updated bathroom, kitchenette and plenty of natural light. Quiet building, close to metro and park.",                             seller:"Maria Stavrou",     si:"MS",img:"https://images.unsplash.com/photo-1502005229762-cf1b2da7c5d6?w=600&h=400&fit=crop&q=80"},
      {id:11, price:"€460,000",raw:460000, address:"Halandri, Athens",    city:"Halandri",    type:"House",      beds:4,baths:2,sqft:"165 m²",listingMode:"buy",  addedDaysAgo:7,  desc:"Modern four-bedroom house in family-friendly Halandri. Open-plan ground floor, garden with pergola, roof terrace. Walking distance to schools and parks.",                 seller:"Nikos Georgiou",    si:"NG",img:"data:image/jpeg;base64,"},
      {id:12, price:"€310,000",raw:310000, address:"Zografou, Athens",    city:"Zografou",    type:"Apartment",  beds:3,baths:1,sqft:"95 m²", listingMode:"buy",  addedDaysAgo:180,desc:"Spacious three-bedroom apartment near the University of Athens. Modern kitchen, wooden floors, balcony and private parking. Quiet street, excellent amenities nearby.",     seller:"Elena Nikolaou",    si:"EN",img:"https://images.unsplash.com/photo-1554995207-c18c203602cb?w=600&h=400&fit=crop&q=80"},
    ]));
    sessionStorage.setItem('hf_appts',JSON.stringify([
      {id:1,buyer:"James T.",buyerId:"buyer",seller:"Sarah M.",property:"Kolonaki Apt",date:"May 08",time:"10:00 AM",loc:"Athens",status:"confirmed"},
      {id:2,buyer:"Ana R.",buyerId:"",seller:"Maria S.",property:"Glyfada Villa",date:"May 14",time:"2:30 PM",loc:"Athens",status:"confirmed"},
      {id:3,buyer:"Nikos P.",buyerId:"",seller:"Sarah M.",property:"Plaka Apt",date:"May 20",time:"11:00 AM",loc:"Athens",status:"confirmed"},
      {id:4,buyer:"Lisa H.",buyerId:"",seller:"Sarah M.",property:"Monastiraki Studio",date:"May 22",time:"9:30 AM",loc:"Athens",status:"pending"},
    ]));
  }
  if(!sessionStorage.getItem('hf_booked')){
    sessionStorage.setItem('hf_booked',JSON.stringify([8,14,20,22]));
  }
}
window.addEventListener("load", initData);
function doLogin(){
  const u=document.getElementById('lu').value.trim();
  const p=document.getElementById('lp').value;
  document.getElementById('lerr').style.display='none';
  initData();
  const users={
    'admin':  {pass:'12345678',name:'Admin User',  role:'admin',  initials:'AU'},
    'seller': {pass:'pass123', name:'Sarah Mitchell',role:'seller',initials:'SM'},
    'buyer':  {pass:'buyer123',name:'James Thompson',role:'buyer', initials:'JT'},
  };
  const found=users[u.toLowerCase()];
  if(found && found.pass===p){
    sessionStorage.setItem('hf_user',JSON.stringify({name:found.name,role:found.role,initials:found.initials}));
    const after=sessionStorage.getItem('hf_after_login');
    sessionStorage.removeItem('hf_after_login');
    const dest=after||{admin:'admin-dash.html',seller:'seller-dash.html',buyer:'buyer-dash.html'}[found.role]||'home.html';
    location.href=dest;
    return;
  }
  if(u && p.length>=6){
    initData();
    sessionStorage.setItem('hf_user',JSON.stringify({name:u,role:'buyer',initials:u.substring(0,2).toUpperCase()}));
    const after2=sessionStorage.getItem('hf_after_login');
    sessionStorage.removeItem('hf_after_login');
    location.href=after2||'home.html';
    return;
  }
  document.getElementById('lerr').style.display='block';
}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
</script>
</body>
</html>