<style>.sbu{background:#1a4a6b!important}.sbav{background:#164070!important}</style>

<style id="chat-styles">
/* Full chat UI for buyer dashboard */
.chat-full-wrap{display:grid;grid-template-columns:260px 1fr;height:520px;border:1px solid var(--br);background:var(--w)}
.cv-list{border-right:1px solid var(--br);display:flex;flex-direction:column;background:var(--w)}
.cv-hdr{padding:14px 16px;background:var(--g);color:#fff}
.cv-hdr h4{font-size:13px;font-weight:700}
.cv-hdr p{font-size:11px;color:rgba(255,255,255,.6);margin-top:1px}
.cv-search{padding:8px 12px;border-bottom:1px solid var(--br)}
.cv-search input{width:100%;padding:7px 10px;border:1px solid var(--br);font-size:12px;font-family:'Inter',sans-serif;outline:none;background:var(--off)}
.cv-search input:focus{border-color:var(--g)}
.cv-items{flex:1;overflow-y:auto}
.cv-item{display:flex;align-items:center;gap:10px;padding:11px 13px;border-bottom:1px solid var(--br);cursor:pointer;transition:background .1s}
.cv-item:hover{background:var(--off)}.cv-item.cv-active{background:var(--gl);border-left:3px solid var(--g)}
.cv-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.cv-info{flex:1;min-width:0}
.cv-name{font-size:12px;font-weight:600;margin-bottom:1px}
.cv-prev{font-size:11px;color:var(--mu);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cv-meta{text-align:right;flex-shrink:0}
.cv-time{font-size:10px;color:var(--li);margin-bottom:2px}
.cv-badge{background:var(--g);color:#fff;border-radius:99px;font-size:9px;font-weight:700;padding:2px 6px}
.chat-panel{display:flex;flex-direction:column;background:var(--off)}
.cp-topbar{padding:11px 18px;border-bottom:1px solid var(--br);background:var(--w);display:flex;align-items:center;gap:10px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.cp-av{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.cp-name{font-size:13px;font-weight:600}.cp-status{font-size:11px;color:var(--g);margin-top:1px}
.cp-acts{display:flex;gap:6px;margin-left:auto}
.cp-act{padding:6px 12px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;cursor:pointer;font-family:'Inter',sans-serif;border:none}
.cp-act-g{background:var(--g);color:#fff}.cp-act-g:hover{background:var(--gd)}
.cp-act-o{background:#fff;color:var(--bl);border:1px solid var(--br)}.cp-act-o:hover{border-color:var(--bl)}
.cp-prop{display:flex;align-items:center;gap:10px;padding:7px 18px;background:#f0f9f5;border-bottom:1px solid #c8e4d6;flex-shrink:0}
.cp-prop-img{width:38px;height:28px;object-fit:cover;border:1px solid #c8e4d6;flex-shrink:0}
.cp-prop-txt{font-size:11px;color:var(--g);font-weight:600}
.cp-prop-addr{font-size:11px;color:var(--mu)}
.cp-msgs{flex:1;overflow-y:auto;padding:18px 18px 10px;display:flex;flex-direction:column;gap:2px}
.cp-mg{display:flex;flex-direction:column;margin-bottom:12px}.cp-mg.me-mg{align-items:flex-end}
.cp-mg-nm{font-size:9px;font-weight:600;color:var(--mu);margin-bottom:3px;padding:0 3px;text-transform:uppercase;letter-spacing:.5px}
.cp-row{display:flex;align-items:flex-end;gap:6px}.cp-row.me-row{flex-direction:row-reverse}
.cp-sm-av{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0}
.cp-bub{padding:9px 13px;font-size:13px;line-height:1.5;max-width:420px}
.cp-bub.them-b{background:#fff;border:1px solid var(--br)}.cp-bub.me-b{background:var(--g);color:#fff}
.cp-ts{font-size:10px;color:var(--li);padding:0 3px;white-space:nowrap}
.cp-date-div{display:flex;align-items:center;gap:10px;margin:12px 0}
.cp-date-line{flex:1;height:1px;background:var(--br)}
.cp-date-txt{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--li);white-space:nowrap}
.cp-sys{text-align:center;font-size:11px;color:var(--mu);background:rgba(30,107,69,.08);border:1px solid rgba(30,107,69,.15);padding:5px 12px;margin:4px auto;max-width:340px}
.cp-input-area{padding:12px 16px;background:#fff;border-top:1px solid var(--br)}
.cp-input-row{display:flex;border:1px solid var(--br)}.cp-input-row:focus-within{border-color:var(--g)}
.cp-input-row textarea{flex:1;padding:10px 13px;background:#fff;border:none;font-size:13px;font-family:'Inter',sans-serif;color:var(--bl);outline:none;resize:none;height:42px;line-height:1.5}
.cp-input-row textarea::placeholder{color:var(--li)}
.cp-send-wrap{display:flex;align-items:flex-end;padding:5px 5px 5px 0}
.cp-send{padding:8px 16px;background:var(--g);color:#fff;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;border:none;cursor:pointer;height:30px;display:flex;align-items:center}.cp-send:hover{background:var(--gd)}
.cp-hint{font-size:10px;color:var(--li);margin-top:4px}
@media(max-width:768px){.chat-full-wrap{grid-template-columns:1fr}.cv-list{display:none}}
</style>
</head>
