<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Buyer Dashboard</title>
<link rel="stylesheet" href="shared.css"/>
<style>.sbu{background:#1a4a6b!important}.sbav{background:#164070!important}</style>
</head>
<body>
<div class="toast" id="toast"></div>

<!-- RESCHEDULE MODAL -->
<div class="ov" id="rescMod">
  <div class="modal" style="max-width:520px">
    <div class="modal-hdr">
      <button class="modal-back" onclick="cm('rescMod')">← Back</button>
      <h2>Reschedule</h2>
      <span style="width:60px"></span>
    </div>
    <div class="modal-body">
      <p>Select a new available date for your appointment.</p>
      <div class="cal-grid" id="resc-cal"></div>
      <div class="fg" style="margin-top:12px"><label class="fl">New Date</label><input type="text" class="fi" id="resc-date" placeholder="Click a date above" readonly/></div>
      <div class="fg"><label class="fl">Time Slot</label><select class="fi" id="resc-time"><option>9:00 AM</option><option>10:00 AM</option><option>11:00 AM</option><option>2:00 PM</option><option>3:30 PM</option><option>5:00 PM</option></select></div>
      <div class="macts">
        <button class="bfu bfu-g" style="max-width:160px" onclick="confirmResc()">Reschedule</button>
        <button class="bfu bfu-o" style="max-width:110px" onclick="cm('rescMod')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<div class="m-overlay" id="mOv" onclick="closeMenu()"></div>
<div class="side-menu" id="sMenu">
  <div class="sm-top"><span class="sm-title">Home Finder</span><button class="sm-x" onclick="closeMenu()">×</button></div>
  <div class="sm-nav">
    <button class="sm-item" onclick="location.href='home.html'">Home</button>
    <button class="sm-item" onclick="location.href='browse.html'">Browse Listings</button>
    <div class="sm-div"></div>
    <button class="sm-item" onclick="logout()">Sign Out</button>
  </div>
  <div class="sm-foot"><span>© 2024 Home Finder</span></div>
</div>
<nav>
  <div class="nav-left"><button class="hbtn" onclick="openMenu()"><span></span><span></span><span></span></button></div>
  <div class="nav-center"><button class="logo" onclick="location.href='home.html'">Home Finder</button></div>
  <div class="nav-right">
    <div class="prof-wrap">
      <div class="prof-btn" id="prof-btn" onclick="toggleProf()" style="background:#1a4a6b">JT</div>
      <div class="prof-drop" id="prof-drop">
        <div class="pd-head"><div class="pd-name" id="pd-name">James Thompson</div><div class="pd-role">Buyer</div></div>
        <button class="pd-item" onclick="showTab('appointments')">My Appointments</button>
        <button class="pd-item" onclick="location.href='browse.html'">Browse Listings</button>
        <button class="pd-item" onclick="showTab('profile')">Edit Profile</button>
        <button class="pd-item" onclick="logout()">Sign Out</button>
      </div>
    </div>
  </div>
</nav>
<main>
<div class="dl">
  <div class="sb2">
    <div class="sbu">
      <div class="sbav buyer-av" id="sb-av">JT</div>
      <div class="sbnm" id="sb-name">James Thompson</div>
      <div class="sbrl buyer">Buyer</div>
    </div>
    <div class="sbmenu">
      <button class="sbi" onclick="showTab('overview')">Overview</button>
      <button class="sbi on" onclick="showTab('appointments')">My Appointments</button>
      <button class="sbi" onclick="showTab('browse')">Browse Listings</button>
      <button class="sbi" onclick="showTab('chat')">Messages</button>
      <button class="sbi" onclick="showTab('profile')">Edit Profile</button>
    </div>
  </div>
  <div class="dash-inner">
    <div class="dash-banner">
      <div class="dash-banner-txt">
        <h3>Athens Property Finder</h3>
        <p>Browse and book viewings across Athens' finest neighbourhoods</p>
      </div>
    </div>
    <div class="mp" id="mp"></div>
  </div>
</div>
<footer class="site-footer"><div class="footer-bottom"><div class="f-copy">© 2024 Home Finder.</div><div class="f-legal"><a href="#">Privacy</a><a href="#">Terms</a></div></div></footer>
</main>
<script>
const USER=JSON.parse(sessionStorage.getItem('hf_user')||'null');
if(!USER||USER.role!=='buyer') location.href='index.html';
function getData(k,d){try{return JSON.parse(sessionStorage.getItem(k)||'null')||d;}catch{return d;}}
function setData(k,v){sessionStorage.setItem(k,JSON.stringify(v));}
let APPTS=getData('hf_appts',[]);
let BOOKED=getData('hf_booked',[8,10,12,15]);
const LS=getData('hf_ls',[]);
let rescId=null,rescDay=null;

if(USER){
  document.getElementById('prof-btn').textContent=USER.initials;
  document.getElementById('pd-name').textContent=USER.name;
  document.getElementById('sb-av').textContent=USER.initials;
  document.getElementById('sb-name').textContent=USER.name;
}

function myAppts(){return APPTS.filter(a=>a.buyerId===USER.role||a.buyer.toLowerCase().includes(USER.name.split(' ')[0].toLowerCase()));}

function showTab(t){
  document.querySelectorAll('.sbi').forEach((b,i)=>b.classList.toggle('on',['overview','appointments','browse','chat','profile'][i]===t));
  const mp=document.getElementById('mp');
  if(t==='overview'){
    const ma=myAppts();
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Overview</h2></div></div>
      <div class="srow" style="grid-template-columns:repeat(3,1fr)">
        <div class="sc2"><div class="sbig">${ma.length}</div><div class="slb">Appointments</div></div>
        <div class="sc2"><div class="sbig">${ma.filter(a=>a.status==='confirmed').length}</div><div class="slb">Confirmed</div></div>
        <div class="sc2"><div class="sbig">3</div><div class="slb">Saved Listings</div></div>
      </div>
      <div class="sh"><div><div class="stag">Upcoming</div><h2 style="font-size:16px">My Appointments</h2></div><button class="sh-link" onclick="showTab('appointments')">Manage →</button></div>
      <table class="dt"><thead><tr><th>Property</th><th>Date</th><th>Time</th><th>Status</th></tr></thead>
      <tbody>${ma.map(a=>`<tr><td>${a.property}</td><td>${a.date}</td><td>${a.time}</td><td><span class="pill ${a.status}">${a.status}</span></td></tr>`).join('')}</tbody></table>`;
  } else if(t==='appointments'){
    const ma=myAppts();
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>My Appointments</h2></div><button class="bsm bsm-g" style="padding:8px 18px;font-size:12px" onclick="location.href='browse.html'">+ Book New</button></div>
      ${ma.length?`<table class="dt"><thead><tr><th>Property</th><th>Location</th><th>Date</th><th>Time</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>${ma.map(a=>`<tr><td style="font-weight:600">${a.property}</td><td>${a.loc}</td><td>${a.date}</td><td>${a.time}</td><td><span class="pill ${a.status}">${a.status}</span></td>
        <td style="display:flex;gap:6px;flex-wrap:wrap">
          ${a.status!=='cancelled'?`<button class="bsm bsm-g" style="padding:4px 10px;font-size:10px" onclick="openResc(${a.id})">Reschedule</button>
          <button class="bsm bsm-o" style="padding:4px 10px;font-size:10px;color:#a03030;border-color:#f5c6c6" onclick="cancelAppt(${a.id})">Cancel</button>`:'<span style="font-size:11px;color:var(--li)">—</span>'}
        </td></tr>`).join('')}</tbody></table>`
      :'<p style="color:var(--mu);font-size:13px;padding:20px 0">No appointments yet. <a href="browse.html" style="color:var(--g);font-weight:600">Browse listings</a> to book a viewing.</p>'}`;
  } else if(t==='browse'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Browse Listings</h2></div></div>
      <div class="lg">${LS.map(l=>`<div class="lc" onclick="openL(${l.id})"><div class="li-img">${l.img?`<img src="${l.img}" alt="${l.address}" loading="lazy"/>`:'<span>Photo</span>'}<div class="li-badge">${l.type}</div></div><div class="li-body"><div class="li-price">${l.price}</div><div class="li-addr">${l.address}</div><div class="li-meta"><span>${l.beds} Bed</span><span>${l.baths} Bath</span></div><div class="li-acts"><button class="bsm bsm-g" onclick="event.stopPropagation();openL(${l.id})">View & Book</button></div></div></div>`).join('')}</div>`;
  } else if(t==='chat'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Messages</h2></div></div>
      <div class="cw"><div class="ch"><div class="cav">S</div><div><div class="cnm">Sarah Mitchell</div><div class="cst">● Online</div></div></div>
      <div class="cms" id="bms"><div class="cmsg"><div class="bub them">Hi! The property at 12 Maple is ready for viewing.</div><div class="mt">09:14</div></div><div class="cmsg me"><div class="bub me">Great, I'll confirm the appointment.</div><div class="mt" style="text-align:right">09:18</div></div></div>
      <div class="cir"><input type="text" id="ci" placeholder="Type a message..." onkeydown="if(event.key==='Enter')sendMsg()"/><button class="csnd" onclick="sendMsg()">Send</button></div></div>`;
  } else if(t==='profile'){
    const nm=USER.name.split(' ');
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Edit Profile</h2></div></div>
      <div style="max-width:400px">
        <div class="frow"><div class="fg"><label class="fl">First Name</label><input type="text" class="fi" value="${nm[0]||'James'}"/></div><div class="fg"><label class="fl">Last Name</label><input type="text" class="fi" value="${nm[1]||'Thompson'}"/></div></div>
        <div class="fg"><label class="fl">Email</label><input type="email" class="fi" value="james.t@email.com"/></div>
        <div class="fg"><label class="fl">Phone</label><input type="tel" class="fi" value="+1 (503) 555-0201"/></div>
        <button class="bsm bsm-g" style="padding:10px 24px;font-size:12px;margin-top:8px" onclick="toast('Profile saved')">Save Changes</button>
      </div>`;
  }
}

function openL(id){sessionStorage.setItem('hf_cur',id);location.href='listing.html';}

function cancelAppt(id){
  APPTS=getData('hf_appts',[]);
  const a=APPTS.find(x=>x.id===id);
  if(a)a.status='cancelled';
  setData('hf_appts',APPTS);
  toast('Appointment cancelled.');
  showTab('appointments');
}

function buildRescCal(){
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  BOOKED=getData('hf_booked',[8,10,12,15]);
  let html=days.map(d=>`<div class="cal-head">${d}</div>`).join('');
  // April 2024: starts Monday (offset=0), 30 days
  for(let d=1;d<=30;d++){
    const booked=BOOKED.includes(d);
    const past=d<=6;
    html+=`<div class="cal-day${booked?' booked':past?' past':''}" onclick="selRescDay(${d},this)"><div class="cal-day-num">${d}</div>${booked?'<div class="cal-booked-lbl">Booked</div>':''}</div>`;
  }
  // pad remaining cells (30 days fills exactly with no pad since 30%7=2, need 5 more)
  const pad=(7-(30%7))%7;
  for(let i=0;i<pad;i++) html+=`<div class="cal-day past" style="min-height:64px"></div>`;
  document.getElementById('resc-cal').innerHTML=html;
}

function openResc(id){
  rescId=id;rescDay=null;
  document.getElementById('resc-date').value='';
  buildRescCal();
  om('rescMod');
}
function selRescDay(d,el){
  if(el.classList.contains('booked')){toast('Already booked.');return;}
  document.querySelectorAll('#resc-cal .cal-day').forEach(x=>x.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('resc-date').value='Apr '+d+', 2024';
  rescDay=d;
}
function confirmResc(){
  if(!rescDay){toast('Select a new date first.');return;}
  APPTS=getData('hf_appts',[]);
  const a=APPTS.find(x=>x.id===rescId);
  if(a){a.date='Apr '+rescDay;a.time=document.getElementById('resc-time').value;a.status='confirmed';}
  setData('hf_appts',APPTS);
  cm('rescMod');
  toast('Appointment rescheduled to Apr '+rescDay+'!');
  showTab('appointments');
}

function sendMsg(){
  const inp=document.getElementById('ci');if(!inp||!inp.value.trim())return;
  const box=document.getElementById('bms');
  const t=new Date();const ts=t.getHours()+':'+String(t.getMinutes()).padStart(2,'0');
  box.innerHTML+=`<div class="cmsg me"><div class="bub me">${esc(inp.value.trim())}</div><div class="mt" style="text-align:right">${ts}</div></div>`;
  inp.value='';box.scrollTop=box.scrollHeight;
  setTimeout(()=>{const r=['Of course!','Sounds good!','See you then.','I will check my calendar.'];const t2=new Date();box.innerHTML+=`<div class="cmsg"><div class="bub them">${r[Math.floor(Math.random()*r.length)]}</div><div class="mt">${t2.getHours()}:${String(t2.getMinutes()).padStart(2,'0')}</div></div>`;box.scrollTop=box.scrollHeight;},1000);
}

function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function om(id){document.getElementById(id).classList.add('on');}
function cm(id){document.getElementById(id).classList.remove('on');}
document.querySelectorAll('.ov').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('on');}));
function logout(){sessionStorage.removeItem('hf_user');location.href='index.html';}
function openMenu(){document.getElementById('mOv').classList.add('on');document.getElementById('sMenu').classList.add('on');}
function closeMenu(){document.getElementById('mOv').classList.remove('on');document.getElementById('sMenu').classList.remove('on');}
function toggleProf(){document.getElementById('prof-drop').classList.toggle('on');}
document.addEventListener('click',e=>{if(!e.target.closest('.prof-wrap'))document.getElementById('prof-drop').classList.remove('on');});
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
showTab('appointments');
</script>
</body>
</html>