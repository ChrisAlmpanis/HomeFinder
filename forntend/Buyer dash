<script>
const USER=getUser();
function getData(k,d){try{return JSON.parse(sessionStorage.getItem(k)||'null')||d;}catch{return d;}}
function setData(k,v){sessionStorage.setItem(k,JSON.stringify(v));}
let APPTS=getData('hf_appts',[]);
let BOOKED=getData('hf_booked',[8,10,12,15]);
const LS=getData('hf_ls',[]);
let rescId=null,rescDay=null;

if(USER){
  document.getElementById('prof-btn').textContent=USER.initials;
  document.getElementById('pd-name').textContent=USER.name;
  document.getElementById('sb-av').textContent=USER.initials;
  document.getElementById('sb-name').textContent=USER.name;
}

function myAppts(){return APPTS.filter(a=>a.buyerId===USER.role||a.buyer.toLowerCase().includes(USER.name.split(' ')[0].toLowerCase()));}

function showTab(t){
  document.querySelectorAll('.sbi').forEach((b,i)=>b.classList.toggle('on',['overview','appointments','browse','chat','profile'][i]===t));
  const mp=document.getElementById('mp');
  if(t==='overview'){
    const ma=myAppts();
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Overview</h2></div></div>
      <div class="srow" style="grid-template-columns:repeat(3,1fr)">
        <div class="sc2"><div class="sbig">${ma.length}</div><div class="slb">Appointments</div></div>
        <div class="sc2"><div class="sbig">${ma.filter(a=>a.status==='confirmed').length}</div><div class="slb">Confirmed</div></div>
        <div class="sc2"><div class="sbig">3</div><div class="slb">Saved Listings</div></div>
      </div>
      <div class="sh"><div><div class="stag">Upcoming</div><h2 style="font-size:16px">My Appointments</h2></div><button class="sh-link" onclick="showTab('appointments')">Manage →</button></div>
      <table class="dt"><thead><tr><th>Property</th><th>Date</th><th>Time</th><th>Status</th></tr></thead>
      <tbody>${ma.map(a=>`<tr><td>${a.property}</td><td>${a.date}</td><td>${a.time}</td><td><span class="pill ${a.status}">${a.status}</span></td></tr>`).join('')}</tbody></table>`;
  } else if(t==='appointments'){
    const ma=myAppts();
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>My Appointments</h2></div><button class="bsm bsm-g" style="padding:8px 18px;font-size:12px" onclick="location.href='home.html'">+ Book New</button></div>
      ${ma.length?`<table class="dt"><thead><tr><th>Property</th><th>Location</th><th>Date</th><th>Time</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>${ma.map(a=>`<tr><td style="font-weight:600">${a.property}</td><td>${a.loc}</td><td>${a.date}</td><td>${a.time}</td><td><span class="pill ${a.status}">${a.status}</span></td>
        <td style="display:flex;gap:6px;flex-wrap:wrap">
          ${a.status!=='cancelled'?`<button class="bsm bsm-g" style="padding:4px 10px;font-size:10px" onclick="openResc(${a.id})">Reschedule</button>
          <button class="bsm bsm-o" style="padding:4px 10px;font-size:10px;color:#a03030;border-color:#f5c6c6" onclick="cancelAppt(${a.id})">Cancel</button>`:'<span style="font-size:11px;color:var(--li)">—</span>'}
        </td></tr>`).join('')}</tbody></table>`
      :'<p style="color:var(--mu);font-size:13px;padding:20px 0">No appointments yet. <a href="home.html" style="color:var(--g);font-weight:600">Browse listings</a> to book a viewing.</p>'}`;
  } else if(t==='browse'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Browse Listings</h2></div></div>
      <div class="lg">${LS.map(l=>`<div class="lc" onclick="openL(${l.id})"><div class="li-img">${l.img?`<img src="${l.img}" alt="${l.address}" loading="lazy" referrerpolicy="no-referrer"/>`:'<span>Photo</span>'}<div class="li-badge">${l.type}</div></div><div class="li-body"><div class="li-price">${l.price}</div><div class="li-addr">${l.address}</div><div class="li-meta"><span>${l.beds} Bed</span><span>${l.baths} Bath</span></div><div class="li-acts"><button class="bsm bsm-g" onclick="event.stopPropagation();openL(${l.id})">View & Book</button></div></div></div>`).join('')}</div>`;
  } else if(t==='chat'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Messages</h2></div></div>
      <div class="chat-full-wrap">
        <div class="cv-list">
          <div class="cv-hdr"><h4>Conversations</h4><p>Your seller messages</p></div>
          <div class="cv-search"><input type="text" placeholder="Search…" oninput="filterCV(this.value)"/></div>
          <div class="cv-items" id="cv-items"></div>
        </div>
        <div class="chat-panel">
          <div class="cp-topbar" id="cp-topbar"></div>
          <div class="cp-prop" id="cp-prop"></div>
          <div class="cp-msgs" id="cp-msgs"></div>
          <div class="cp-input-area">
            <div class="cp-input-row">
              <textarea id="cp-inp" placeholder="Type a message…" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendCpMsg();}"></textarea>
              <div class="cp-send-wrap"><button class="cp-send" onclick="sendCpMsg()">Send</button></div>
            </div>
            <div class="cp-hint">Enter to send · Shift+Enter for new line</div>
          </div>
        </div>
      </div>`;
    initChat();
  } else if(t==='profile'){
    const nm=USER.name.split(' ');
    mp.innerHTML=`<div class="sh"><div><div class="stag">Buyer</div><h2>Edit Profile</h2></div></div>
      <div style="max-width:400px">
        <div class="frow"><div class="fg"><label class="fl">First Name</label><input type="text" class="fi" value="${nm[0]||'James'}"/></div><div class="fg"><label class="fl">Last Name</label><input type="text" class="fi" value="${nm[1]||'Thompson'}"/></div></div>
        <div class="fg"><label class="fl">Email</label><input type="email" class="fi" value="james.t@email.com"/></div>
        <div class="fg"><label class="fl">Phone</label><input type="tel" class="fi" value="+1 (503) 555-0201"/></div>
        <button class="bsm bsm-g" style="padding:10px 24px;font-size:12px;margin-top:8px" onclick="toast('Profile saved')">Save Changes</button>
      </div>`;
  }
}

function openL(id){sessionStorage.setItem('hf_cur',id);location.href='home.html';}

function cancelAppt(id){
  APPTS=getData('hf_appts',[]);
  const a=APPTS.find(x=>x.id===id);
  if(a)a.status='cancelled';
  setData('hf_appts',APPTS);
  toast('Appointment cancelled.');
  showTab('appointments');
}

function buildRescCal(){
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  BOOKED=getData('hf_booked',[8,10,12,15]);
  let html=days.map(d=>`<div class="cal-head">${d}</div>`).join('');
  // April 2024: starts Monday (offset=0), 30 days
  for(let d=1;d<=30;d++){
    const booked=BOOKED.includes(d);
    const past=d<=6;
    html+=`<div class="cal-day${booked?' booked':past?' past':''}" onclick="selRescDay(${d},this)"><div class="cal-day-num">${d}</div>${booked?'<div class="cal-booked-lbl">Booked</div>':''}</div>`;
  }
  // pad remaining cells (30 days fills exactly with no pad since 30%7=2, need 5 more)
  const pad=(7-(30%7))%7;
  for(let i=0;i<pad;i++) html+=`<div class="cal-day past" style="min-height:64px"></div>`;
  document.getElementById('resc-cal').innerHTML=html;
}

function openResc(id){
  rescId=id;rescDay=null;
  document.getElementById('resc-date').value='';
  buildRescCal();
  om('rescMod');
}
function selRescDay(d,el){
  if(el.classList.contains('booked')){toast('Already booked.');return;}
  document.querySelectorAll('#resc-cal .cal-day').forEach(x=>x.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('resc-date').value='Apr '+d+', 2024';
  rescDay=d;
}
function confirmResc(){
  if(!rescDay){toast('Select a new date first.');return;}
  APPTS=getData('hf_appts',[]);
  const a=APPTS.find(x=>x.id===rescId);
  if(a){a.date='Apr '+rescDay;a.time=document.getElementById('resc-time').value;a.status='confirmed';}
  setData('hf_appts',APPTS);
  cm('rescMod');
  toast('Appointment rescheduled to Apr '+rescDay+'!');
  showTab('appointments');
}

// ── Full chat system ──
const CONVOS_B=[
  {id:1,seller:'Yannis Papadopoulos',si:'YP',color:'#1e6b45',property:'Kolonaki House',price:'€485,000',img:'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=80&h=60&fit=crop',preview:'The house is available for viewing this week.',time:'10:41',unread:0,messages:[
    {me:false,text:'Good morning! I saw you were interested in the Kolonaki property.',time:'10:32'},
    {me:true, text:'Yes, it looks great! Is it still available?',time:'10:34'},
    {me:false,text:'Absolutely. Would you like to arrange a viewing?',time:'10:36'},
    {me:true, text:'That would be perfect. When are you free?',time:'10:38'},
    {me:false,text:'The house is available for viewing this week.',time:'10:41'},
  ]},
  {id:2,seller:'Maria Stavrou',si:'MS',color:'#1a4a6b',property:'Plaka Apartment',price:'€350,000',img:'https://images.unsplash.com/photo-1484154218962-a197022b5858?w=80&h=60&fit=crop',preview:'The apartment has stunning Parthenon views.',time:'Yesterday',unread:2,messages:[
    {me:false,text:'Hello! The Plaka apartment has stunning Parthenon views from the rooftop terrace.',time:'09:14'},
    {me:true, text:'That sounds amazing. What floor is it on?',time:'09:20'},
    {me:false,text:'4th floor with a rooftop terrace. Stone walls and original features.',time:'09:22'},
    {me:false,text:'The apartment has stunning Parthenon views.',time:'09:23'},
  ]},
  {id:3,seller:'Elena Nikolaou',si:'EN',color:'#7b3a00',property:'Kifisia House',price:'€620,000',img:'https://images.unsplash.com/photo-1583608205776-bfd35f0d9f83?w=80&h=60&fit=crop',preview:'I can arrange a viewing for next week.',time:'Mon',unread:0,messages:[
    {me:false,text:'Hi! Thanks for your interest in the Kifisia property.',time:'14:05'},
    {me:true, text:'It looks beautiful. Is the garden maintained?',time:'14:10'},
    {me:false,text:'Yes, fully maintained. I can arrange a viewing for next week.',time:'14:12'},
  ]},
];
let activeCvId=1;
function initChat(){renderCvList();openCv(activeCvId);}
function filterCV(v){renderCvList(v);}
function renderCvList(filter=''){
  const el=document.getElementById('cv-items');if(!el)return;
  const html=CONVOS_B.filter(c=>!filter||c.seller.toLowerCase().includes(filter.toLowerCase())||c.property.toLowerCase().includes(filter.toLowerCase())).map(c=>`
    <div class="cv-item${c.id===activeCvId?' cv-active':''}" onclick="openCv(${c.id})">
      <div class="cv-av" style="background:${c.color}">${c.si}</div>
      <div class="cv-info"><div class="cv-name">${c.seller}</div><div class="cv-prev">${c.preview}</div></div>
      <div class="cv-meta"><div class="cv-time">${c.time}</div>${c.unread>0?`<span class="cv-badge">${c.unread}</span>`:''}</div>
    </div>`).join('');
  el.innerHTML=html||'<p style="padding:16px;font-size:12px;color:var(--li);text-align:center">No conversations</p>';
}
function openCv(id){
  activeCvId=id;
  const cv=CONVOS_B.find(x=>x.id===id);if(!cv)return;
  cv.unread=0; renderCvList();
  const un=USER?USER.name:'You';const ui=USER?USER.initials:'JT';
  const tb=document.getElementById('cp-topbar');
  const pp=document.getElementById('cp-prop');
  const mb=document.getElementById('cp-msgs');
  if(!tb||!pp||!mb)return;
  tb.innerHTML=`<div class="cp-av" style="background:${cv.color}">${cv.si}</div>
    <div><div class="cp-name">${cv.seller}</div><div class="cp-status">● Online · Verified Seller</div></div>
    <div class="cp-acts">
      <button class="cp-act cp-act-g" onclick="location.href='home.html'">View Property</button>
      <button class="cp-act cp-act-o">Book Viewing</button>
    </div>`;
  pp.innerHTML=cv.img?`<img class="cp-prop-img" src="${cv.img}" alt="" referrerpolicy="no-referrer"/>
    <div><div class="cp-prop-txt">${cv.price} · ${cv.property}</div></div>`:'';
  let html=`<div class="cp-date-div"><div class="cp-date-line"></div><div class="cp-date-txt">Today</div><div class="cp-date-line"></div></div>`;
  html+=`<div class="cp-sys">You are connected with ${cv.seller} about ${cv.property}</div>`;
  let lastS=null;
  cv.messages.forEach((m,i)=>{
    const s=m.me?'me':'them';
    if(s!==lastS){if(i>0)html+='</div>';html+=`<div class="cp-mg${m.me?' me-mg':''}">`;}
    html+=`<div class="cp-row${m.me?' me-row':''}">
      ${!m.me&&s!==lastS?`<div class="cp-sm-av" style="background:${cv.color}">${cv.si}</div>`:'<div style="width:24px"></div>'}
      <div class="cp-bub ${m.me?'me-b':'them-b'}">${esc(m.text)}</div>
      ${m.me&&s!==lastS?`<div class="cp-sm-av" style="background:#1a4a6b">${ui}</div>`:'<div style="width:24px"></div>'}
      <span class="cp-ts">${m.time}</span>
    </div>`;
    lastS=s;
  });
  if(lastS)html+='</div>';
  mb.innerHTML=html; mb.scrollTop=mb.scrollHeight;
}
function sendCpMsg(){
  const inp=document.getElementById('cp-inp');if(!inp||!inp.value.trim())return;
  const cv=CONVOS_B.find(x=>x.id===activeCvId);if(!cv)return;
  const t=new Date();const ts=t.getHours()+':'+String(t.getMinutes()).padStart(2,'0');
  cv.messages.push({me:true,text:inp.value.trim(),time:ts});cv.preview=inp.value.trim();cv.time='Now';
  inp.value=''; openCv(activeCvId); renderCvList();
  setTimeout(()=>{
    const r=['Of course! I will check my schedule.','Sounds good!','Looking forward to the viewing.','I will confirm shortly.','Feel free to call anytime.'];
    const t2=new Date();
    cv.messages.push({me:false,text:r[Math.floor(Math.random()*r.length)],time:t2.getHours()+':'+String(t2.getMinutes()).padStart(2,'0')});
    cv.preview=cv.messages[cv.messages.length-1].text;
    openCv(activeCvId);renderCvList();
  },1100);
}
function sendMsg(){sendCpMsg();}

function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function om(id){document.getElementById(id).classList.add('on');}
function cm(id){document.getElementById(id).classList.remove('on');}
document.querySelectorAll('.ov').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('on');}));
function openMenu(){document.getElementById('mOv').classList.add('on');document.getElementById('sMenu').classList.add('on');}
function closeMenu(){document.getElementById('mOv').classList.remove('on');document.getElementById('sMenu').classList.remove('on');}
function toggleProf(){document.getElementById('prof-drop').classList.toggle('on');}
document.addEventListener('click',e=>{if(!e.target.closest('.prof-wrap'))document.getElementById('prof-drop').classList.remove('on');});
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
showTab('appointments');
</script>
