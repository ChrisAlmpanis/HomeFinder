<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Admin Dashboard</title>
<link rel="stylesheet" href="shared.css"/>
<style>.sbu{background:#6b1a1a!important}.sbav{background:#521414!important}</style>
</head>
<body>
<div class="toast" id="toast"></div>
<div class="m-overlay" id="mOv" onclick="closeMenu()"></div>
<div class="side-menu" id="sMenu">
  <div class="sm-top"><span class="sm-title">Home Finder</span><button class="sm-x" onclick="closeMenu()">×</button></div>
  <div class="sm-nav">
    <button class="sm-item" onclick="location.href='home.html'">Home</button>
    <button class="sm-item" onclick="location.href='browse.html'">Browse Listings</button>
    <div class="sm-div"></div>
    <button class="sm-item" onclick="logout()">Sign Out</button>
  </div>
  <div class="sm-foot"><span>© 2024 Home Finder</span></div>
</div>
<nav>
  <div class="nav-left"><button class="hbtn" onclick="openMenu()"><span></span><span></span><span></span></button></div>
  <div class="nav-center"><button class="logo" onclick="location.href='home.html'">Home Finder</button></div>
  <div class="nav-right">
    <div class="prof-wrap">
      <div class="prof-btn" onclick="toggleProf()" style="background:#6b1a1a">AU</div>
      <div class="prof-drop" id="prof-drop">
        <div class="pd-head"><div class="pd-name">Admin User</div><div class="pd-role" style="color:#a03030">Administrator</div></div>
        <button class="pd-item" onclick="showTab('users')">Manage Users</button>
        <button class="pd-item" onclick="showTab('approvals')">Pending Approvals</button>
        <button class="pd-item" onclick="showTab('appointments')">Appointments</button>
        <button class="pd-item" onclick="logout()">Sign Out</button>
      </div>
    </div>
  </div>
</nav>
<main>
<div class="dl">
  <div class="sb2">
    <div class="sbu">
      <div class="sbav adm-av">AU</div>
      <div class="sbnm">Admin User</div>
      <div class="sbrl adm">Administrator</div>
    </div>
    <div class="sbmenu">
      <button class="sbi on" onclick="showTab('users')">Users</button>
      <button class="sbi" onclick="showTab('approvals')">Pending Approvals</button>
      <button class="sbi" onclick="showTab('listings')">Listings</button>
      <button class="sbi" onclick="showTab('appointments')">Appointments</button>
      <button class="sbi" onclick="showTab('profile')">Profile</button>
    </div>
  </div>
  <div class="dash-inner">
    <div class="dash-banner">
      <div class="dash-banner-txt">
        <h3>Athens Home Finder — Admin Panel</h3>
        <p>Manage users, listings and appointments across Athens</p>
      </div>
    </div>
    <div class="mp" id="mp"></div>
  </div>
</div>
<footer class="site-footer"><div class="footer-bottom"><div class="f-copy">© 2024 Home Finder.</div><div class="f-legal"><a href="#">Privacy</a><a href="#">Terms</a></div></div></footer>
</main>
<script>
const USER=JSON.parse(sessionStorage.getItem('hf_user')||'null');
if(!USER||USER.role!=='admin') location.href='index.html';
function getData(k,d){try{return JSON.parse(sessionStorage.getItem(k)||'null')||d;}catch{return d;}}
function setData(k,v){sessionStorage.setItem(k,JSON.stringify(v));}
let APPTS=getData('hf_appts',[]);
const LS=getData('hf_ls',[]);
const USERS=[
  {name:"James Thompson",email:"james.t@email.com",role:"buyer",joined:"Mar 2024",status:"approved"},
  {name:"Sarah Mitchell",email:"sarah.m@email.com",role:"seller",joined:"Jan 2024",status:"approved"},
  {name:"Ana Rodriguez",email:"ana.r@email.com",role:"buyer",joined:"Apr 2024",status:"approved"},
  {name:"Marco Verdi",email:"marco.v@email.com",role:"seller",joined:"Feb 2024",status:"approved"},
  {name:"Lisa Han",email:"lisa.h@email.com",role:"buyer",joined:"Apr 2024",status:"approved"},
];
let pendingUsers=[
  {name:"John Davies",email:"john.d@email.com",joined:"Today"},
  {name:"Maria Costa",email:"maria.c@email.com",joined:"Today"},
];

function card(l){
  return `<div class="lc" onclick="openL(${l.id})"><div class="li-img">${l.img?`<img src="${l.img}" alt="${l.address}" loading="lazy"/>`:'<span>Photo</span>'}<div class="li-badge">${l.type}</div></div><div class="li-body"><div class="li-price">${l.price}</div><div class="li-addr">${l.address}</div><div class="li-meta"><span>${l.beds} Bed</span><span>${l.baths} Bath</span></div><div class="li-acts"><button class="bsm bsm-g" onclick="event.stopPropagation();toast('Editing listing')">Edit</button><button class="bsm bsm-o" onclick="event.stopPropagation();toast('Listing removed')">Delete</button></div></div></div>`;
}

function showTab(t){
  document.querySelectorAll('.sbi').forEach((b,i)=>b.classList.toggle('on',['users','approvals','listings','appointments','profile'][i]===t));
  APPTS=getData('hf_appts',[]);
  const mp=document.getElementById('mp');
  if(t==='users'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Admin</div><h2>Users</h2></div><span style="font-size:13px;color:var(--mu)">${USERS.length} accounts</span></div>
      <div class="srow" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">${[['12K','Total Users'],['890','Sellers'],['2.4K','Listings']].map(([n,l])=>`<div class="sc2"><div class="sbig">${n}</div><div class="slb">${l}</div></div>`).join('')}</div>
      <table class="dt"><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th></th></tr></thead>
      <tbody>${USERS.map(u=>`<tr><td style="font-weight:600">${u.name}</td><td style="color:var(--mu)">${u.email}</td><td><span class="badge b${u.role[0]}">${u.role}</span></td><td><span class="pill confirmed">${u.status}</span></td><td style="color:var(--mu)">${u.joined}</td><td><button class="lbtn" onclick="toast('Editing ${u.name}')">Edit</button></td></tr>`).join('')}</tbody></table>`;
  } else if(t==='approvals'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Admin</div><h2>Pending Approvals</h2></div><span style="font-size:13px;color:#856404">${pendingUsers.length} pending</span></div>
      <div class="infomsg">Buyers must be approved by an administrator before they can access the platform.</div>
      ${pendingUsers.length?`<table class="dt"><thead><tr><th>Name</th><th>Email</th><th>Registered</th><th>Actions</th></tr></thead>
      <tbody id="pending-tbody">${pendingUsers.map(u=>`<tr id="row-${u.name.replace(' ','')}"><td style="font-weight:600">${u.name}</td><td style="color:var(--mu)">${u.email}</td><td style="color:var(--mu)">${u.joined}</td><td style="display:flex;gap:6px"><button class="bsm bsm-g" onclick="approveUser('${u.name}')">Approve</button><button class="bsm bsm-o" style="color:#a03030;border-color:#f5c6c6" onclick="rejectUser('${u.name}')">Reject</button></td></tr>`).join('')}</tbody></table>`
      :'<p style="font-size:13px;color:var(--mu);padding:20px 0">No pending approvals.</p>'}`;
  } else if(t==='listings'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Admin</div><h2>All Listings</h2></div><button class="bsm bsm-g" style="padding:8px 18px;font-size:12px" onclick="toast('Add new listing')">+ New Listing</button></div>
      <div class="lg">${LS.map(card).join('')}</div>`;
  } else if(t==='appointments'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Admin</div><h2>All Appointments</h2></div></div>
      <div class="infomsg" style="margin-bottom:16px">Admin can override or cancel any appointment in emergencies.</div>
      <table class="dt"><thead><tr><th>Buyer</th><th>Seller</th><th>Property</th><th>Date</th><th>Time</th><th>Status</th><th></th></tr></thead>
      <tbody>${APPTS.map(a=>`<tr><td>${a.buyer}</td><td>${a.seller}</td><td>${a.property}</td><td>${a.date}</td><td>${a.time}</td><td><span class="pill ${a.status}">${a.status}</span></td><td>${a.status!=='cancelled'?`<button class="bsm bsm-o" style="font-size:10px;padding:4px 8px;color:#a03030;border-color:#f5c6c6" onclick="adminCancel(${a.id})">Cancel</button>`:''}</td></tr>`).join('')}</tbody></table>`;
  } else if(t==='profile'){
    mp.innerHTML=`<div class="sh"><div><div class="stag">Admin</div><h2>Profile</h2></div></div>
      <div style="max-width:380px">
        <div class="fg"><label class="fl">Name</label><input type="text" class="fi" value="Admin User"/></div>
        <div class="fg"><label class="fl">Email</label><input type="email" class="fi" value="admin@homefinder.com"/></div>
        <div class="fg"><label class="fl">New Password</label><input type="password" class="fi" placeholder="Leave blank to keep current"/></div>
        <button class="bsm bsm-g" style="padding:10px 24px;font-size:12px;margin-top:8px" onclick="toast('Profile saved')">Save Changes</button>
      </div>`;
  }
}

function approveUser(name){
  pendingUsers=pendingUsers.filter(u=>u.name!==name);
  toast(name+' approved!');
  showTab('approvals');
}
function rejectUser(name){
  pendingUsers=pendingUsers.filter(u=>u.name!==name);
  toast(name+' rejected.');
  showTab('approvals');
}
function adminCancel(id){
  APPTS=getData('hf_appts',[]);
  const a=APPTS.find(x=>x.id===id);
  if(a)a.status='cancelled';
  setData('hf_appts',APPTS);
  toast('Appointment cancelled by admin.');
  showTab('appointments');
}
function openL(id){sessionStorage.setItem('hf_cur',id);location.href='listing.html';}
function logout(){sessionStorage.removeItem('hf_user');location.href='index.html';}
function openMenu(){document.getElementById('mOv').classList.add('on');document.getElementById('sMenu').classList.add('on');}
function closeMenu(){document.getElementById('mOv').classList.remove('on');document.getElementById('sMenu').classList.remove('on');}
function toggleProf(){document.getElementById('prof-drop').classList.toggle('on');}
document.addEventListener('click',e=>{if(!e.target.closest('.prof-wrap'))document.getElementById('prof-drop').classList.remove('on');});
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
showTab('users');
</script>
</body>
</html>