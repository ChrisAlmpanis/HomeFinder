<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Chat</title>
<link rel="stylesheet" href="shared.css"/>
</head>
<body>
<div class="toast" id="toast"></div>
<div class="m-overlay" id="mOv" onclick="closeMenu()"></div>
<div class="side-menu" id="sMenu">
  <div class="sm-top"><span class="sm-title">Home Finder</span><button class="sm-x" onclick="closeMenu()">×</button></div>
  <div class="sm-nav">
    <button class="sm-item" onclick="location.href='home.html'">Home</button>
    <button class="sm-item" onclick="location.href='browse.html'">Browse Listings</button>
    <div class="sm-div"></div>
    <div id="sm-auth-links"></div>
  </div>
  <div class="sm-foot"><span>© 2024 Home Finder</span></div>
</div>
<nav>
  <div class="nav-left"><button class="hbtn" onclick="openMenu()"><span></span><span></span><span></span></button></div>
  <div class="nav-center"><button class="logo" onclick="location.href='home.html'">Home Finder</button></div>
  <div class="nav-right">
    <div class="prof-wrap">
      <div class="prof-btn" id="prof-btn" onclick="toggleProf()">G</div>
      <div class="prof-drop" id="prof-drop">
        <div class="pd-head"><div class="pd-name" id="pd-name">Guest</div><div class="pd-role" id="pd-role"></div></div>
        <div id="pd-links"></div>
      </div>
    </div>
  </div>
</nav>
<main>
<div class="ct">
  <div class="sh">
    <div><div class="stag">Messages</div><h2>Sarah Mitchell</h2></div>
    <button class="sh-link" onclick="location.href='listing.html'">← Back to Listing</button>
  </div>
  <div class="cw">
    <div class="ch">
      <div class="cav">S</div>
      <div><div class="cnm">Sarah Mitchell</div><div class="cst">● Online</div></div>
    </div>
    <div class="cms" id="cms">
      <div class="cmsg"><div class="bub them">Hi — I saw you were interested in 12 Maple Avenue. Is there anything you'd like to know?</div><div class="mt">10:32</div></div>
      <div class="cmsg me"><div class="bub me">Yes, I'd love to arrange a viewing. Is Saturday morning available?</div><div class="mt" style="text-align:right">10:35</div></div>
      <div class="cmsg"><div class="bub them">Saturday works great! I can do 10:30 AM. Shall I confirm that for you?</div><div class="mt">10:37</div></div>
      <div class="cmsg me"><div class="bub me">That's perfect. Please confirm 10:30 AM Saturday.</div><div class="mt" style="text-align:right">10:40</div></div>
      <div class="cmsg"><div class="bub them">Confirmed! I'll send you the full address details shortly. See you then!</div><div class="mt">10:41</div></div>
    </div>
    <div class="cir">
      <input type="text" id="cinp" placeholder="Type a message..." onkeydown="if(event.key==='Enter')send()"/>
      <button class="csnd" onclick="send()">Send</button>
    </div>
  </div>
</div>
<footer class="site-footer">
  <div class="footer-bottom"><div class="f-copy">© 2024 Home Finder.</div><div class="f-legal"><a href="#">Privacy</a><a href="#">Terms</a></div></div>
</footer>
</main>
<script>
const USER=JSON.parse(sessionStorage.getItem('hf_user')||'null');
if(!USER) location.href='index.html';

function setupNav(){
  if(USER){
    document.getElementById('prof-btn').textContent=USER.initials;
    document.getElementById('pd-name').textContent=USER.name;
    document.getElementById('pd-role').textContent=USER.role;
    const dashUrl={admin:'admin-dash.html',seller:'seller-dash.html',buyer:'buyer-dash.html'}[USER.role]||'home.html';
    document.getElementById('pd-links').innerHTML=`<button class="pd-item" onclick="location.href='${dashUrl}'">My Dashboard</button><button class="pd-item" onclick="logout()">Sign Out</button>`;
    document.getElementById('sm-auth-links').innerHTML=`<button class="sm-item" onclick="location.href='${dashUrl}'">My Dashboard</button><button class="sm-item" onclick="logout()">Sign Out</button>`;
  }
}
setupNav();

const replies=["Thanks, I will get back to you shortly.","Sounds good!","Looking forward to the viewing.","Feel free to call anytime.","That works perfectly.","I will check the calendar and confirm."];
function send(){
  const inp=document.getElementById('cinp');
  const txt=inp.value.trim();if(!txt)return;
  const box=document.getElementById('cms');
  const t=new Date();const ts=t.getHours()+':'+String(t.getMinutes()).padStart(2,'0');
  box.innerHTML+=`<div class="cmsg me"><div class="bub me">${esc(txt)}</div><div class="mt" style="text-align:right">${ts}</div></div>`;
  inp.value='';box.scrollTop=box.scrollHeight;
  setTimeout(()=>{const t2=new Date();box.innerHTML+=`<div class="cmsg"><div class="bub them">${replies[Math.floor(Math.random()*replies.length)]}</div><div class="mt">${t2.getHours()}:${String(t2.getMinutes()).padStart(2,'0')}</div></div>`;box.scrollTop=box.scrollHeight;},1100);
}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function logout(){sessionStorage.removeItem('hf_user');location.href='index.html';}
function openMenu(){document.getElementById('mOv').classList.add('on');document.getElementById('sMenu').classList.add('on');}
function closeMenu(){document.getElementById('mOv').classList.remove('on');document.getElementById('sMenu').classList.remove('on');}
function toggleProf(){document.getElementById('prof-drop').classList.toggle('on');}
document.addEventListener('click',e=>{if(!e.target.closest('.prof-wrap'))document.getElementById('prof-drop').classList.remove('on');});
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
</script>
</body>
</html>