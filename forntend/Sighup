<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Create Account</title>
<link rel="stylesheet" href="shared.css"/>
</head>
<body>
<div class="toast" id="toast"></div>
<nav>
  <div class="nav-left"></div>
  <div class="nav-center"><button class="logo" onclick="location.href='home.html'">Home Finder</button></div>
  <div class="nav-right"></div>
</nav>
<main>
<div class="fp">
  <div class="fbox">
    <div class="ftitle">Create Account</div>
    <div class="fsub">Join Home Finder as a buyer or seller.</div>
    <div class="infomsg" id="reg-note" style="display:none">⚠ Buyer accounts require admin approval before you can access the platform.</div>
    <div class="fl" style="margin-bottom:10px">I am a</div>
    <div class="rgrid">
      <div class="rc on" id="r-buyer" onclick="selRole('buyer')"><div class="ri">🏠</div><div class="rl">Buyer</div></div>
      <div class="rc" id="r-seller" onclick="selRole('seller')"><div class="ri">🔑</div><div class="rl">Seller</div></div>
    </div>
    <div class="frow">
      <div class="fg"><label class="fl">First Name</label><input type="text" class="fi" placeholder="Jane"/></div>
      <div class="fg"><label class="fl">Last Name</label><input type="text" class="fi" placeholder="Smith"/></div>
    </div>
    <div class="fg"><label class="fl">Email</label><input type="email" class="fi" placeholder="you@email.com"/></div>
    <div class="fg"><label class="fl">Phone</label><input type="tel" class="fi" placeholder="+1 (000) 000-0000"/></div>
    <div class="frow">
      <div class="fg"><label class="fl">Password</label><input type="password" class="fi" placeholder="••••••••"/></div>
      <div class="fg"><label class="fl">Confirm</label><input type="password" class="fi" placeholder="••••••••"/></div>
    </div>
    <div id="co-field" style="display:none" class="fg"><label class="fl">Company (optional)</label><input type="text" class="fi" placeholder="Acme Realty"/></div>
    <button class="bfu bfu-g" style="margin-top:8px" onclick="doSignup()">Create Account</button>
    <div class="fdiv"><div class="fdl"></div><div class="fdt">or</div><div class="fdl"></div></div>
    <button class="bfu bfu-o" onclick="location.href='index.html'">Back to Sign In</button>
  </div>
</div>
</main>
<script>
let role='buyer';
function selRole(r){
  role=r;
  ['buyer','seller'].forEach(x=>document.getElementById('r-'+x).classList.remove('on'));
  document.getElementById('r-'+r).classList.add('on');
  document.getElementById('co-field').style.display=r==='seller'?'block':'none';
  document.getElementById('reg-note').style.display=r==='buyer'?'block':'none';
}
function doSignup(){
  toast(role==='buyer'?'Account created! Awaiting admin approval.':'Account created! Welcome aboard.');
  setTimeout(()=>location.href='index.html',1500);
}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3000);}
</script>
</body>
</html>