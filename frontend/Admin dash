<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="referrer" content="no-referrer"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Home Finder — Admin Dashboard</title>
<link rel="stylesheet" href="shared.css"/>
<style>.sbu{background:#6b1a1a!important}.sbav{background:#521414!important}</style>
</head>
<body>
<div class="toast" id="toast"></div>

<!-- EDIT USER MODAL -->
<div class="ov" id="editUserMod">
  <div class="modal" style="max-width:440px">
    <div class="modal-hdr"><button class="modal-back" onclick="cm('editUserMod')">← Back</button><h2>Edit User</h2><span style="width:60px"></span></div>
    <div class="modal-body">
      <div class="fg"><label class="fl">Full Name</label><input type="text" class="fi" id="eu-name"/></div>
      <div class="fg"><label class="fl">Email</label><input type="email" class="fi" id="eu-email"/></div>
      <div class="fg"><label class="fl">Role</label>
        <select class="fi" id="eu-role"><option value="buyer">Buyer</option><option value="seller">Seller</option><option value="admin">Admin</option></select>
      </div>
      <div class="fg"><label class="fl">Status</label>
        <select class="fi" id="eu-status"><option value="approved">Approved</option><option value="pending">Pending</option><option value="suspended">Suspended</option></select>
      </div>
      <div class="macts">
        <button class="bfu bfu-g" style="max-width:140px" onclick="saveUser()">Save Changes</button>
        <button class="bfu bfu-o" style="max-width:110px" onclick="cm('editUserMod')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- EDIT LISTING MODAL -->
<div class="ov" id="editListingMod">
  <div class="modal" style="max-width:480px">
    <div class="modal-hdr"><button class="modal-back" onclick="cm('editListingMod')">← Back</button><h2>Edit Listing</h2><span style="width:60px"></span></div>
    <div class="modal-body">
      <div class="frow">
        <div class="fg"><label class="fl">Price (€)</label><input type="number" class="fi" id="el-price"/></div>
        <div class="fg"><label class="fl">Type</label>
          <select class="fi" id="el-type"><option>House</option><option>Apartment</option><option>Studio</option><option>Townhouse</option></select>
        </div>
      </div>
      <div class="fg"><label class="fl">Address</label><input type="text" class="fi" id="el-addr"/></div>
      <div class="frow">
        <div class="fg"><label class="fl">Bedrooms</label><input type="number" class="fi" id="el-beds" min="1"/></div>
        <div class="fg"><label class="fl">Bathrooms</label><input type="number" class="fi" id="el-baths" min="1"/></div>
      </div>
      <div class="fg"><label class="fl">Description</label><textarea class="fi" id="el-desc" rows="3" style="resize:vertical"></textarea></div>
      <div class="macts">
        <button class="bfu bfu-g" style="max-width:140px" onclick="saveListing()">Save Changes</button>
        <button class="bfu bfu-o" style="max-width:110px" onclick="cm('editListingMod')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- CONFIRM DELETE MODAL -->
<div class="ov" id="confirmDelMod">
  <div class="modal" style="max-width:400px">
    <div class="modal-hdr"><button class="modal-back" onclick="cm('confirmDelMod')">← Back</button><h2>Confirm Delete</h2><span style="width:60px"></span></div>
    <div class="modal-body">
      <p id="del-msg">Are you sure you want to delete this item? This cannot be undone.</p>
      <div class="macts">
        <button class="bfu" style="max-width:140px;background:#c0392b;color:#fff;border:none" onclick="confirmDelete()">Delete</button>
        <button class="bfu bfu-o" style="max-width:110px" onclick="cm('confirmDelMod')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- NEW LISTING MODAL -->
<div class="ov" id="nlMod">
  <div class="modal" style="max-width:480px">
    <div class="modal-hdr"><button class="modal-back" onclick="cm('nlMod')">← Back</button><h2>New Listing</h2><span style="width:60px"></span></div>
    <div class="modal-body">
      <div class="frow">
        <div class="fg"><label class="fl">Address</label><input type="text" class="fi" id="nl-addr" placeholder="Kolonaki, Athens"/></div>
        <div class="fg"><label class="fl">Price (€)</label><input type="number" class="fi" id="nl-price" placeholder="400000"/></div>
      </div>
      <div class="frow">
        <div class="fg"><label class="fl">Type</label><select class="fi" id="nl-type"><option>House</option><option>Apartment</option><option>Studio</option></select></div>
        <div class="fg"><label class="fl">Bedrooms</label><input type="number" class="fi" id="nl-beds" placeholder="3" min="1"/></div>
      </div>
      <div class="frow">
        <div class="fg"><label class="fl">Bathrooms</label><input type="number" class="fi" id="nl-baths" placeholder="2" min="1"/></div>
        <div class="fg"><label class="fl">Size</label><input type="text" class="fi" id="nl-sqft" placeholder="120 m²"/></div>
      </div>
      <div class="fg"><label class="fl">Description</label><textarea class="fi" id="nl-desc" rows="2" style="resize:vertical" placeholder="Describe the property..."></textarea></div>
      <div class="macts">
        <button class="bfu bfu-g" style="max-width:140px" onclick="addListing()">Add Listing</button>
        <button class="bfu bfu-o" style="max-width:110px" onclick="cm('nlMod')">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- CANCEL APPOINTMENT CONFIRM -->
<div class="ov" id="cancelApptMod">
  <div class="modal" style="max-width:400px">
    <div class="modal-hdr"><button class="modal-back" onclick="cm('cancelApptMod')">← Back</button><h2>Cancel Appointment</h2><span style="width:60px"></span></div>
    <div class="modal-body">
      <p id="ca-msg">Cancel this appointment? The buyer will be notified.</p>
      <div class="macts">
        <button class="bfu" style="max-width:160px;background:#c0392b;color:#fff;border:none" onclick="doAdminCancel()">Yes, Cancel It</button>
        <button class="bfu bfu-o" style="max-width:110px" onclick="cm('cancelApptMod')">Back</button>
      </div>
    </div>
  </div>
</div>

<div class="m-overlay" id="mOv" onclick="closeMenu()"></div>
<div class="side-menu" id="sMenu">
  <div class="sm-top"><span class="sm-title">Home Finder</span><button class="sm-x" onclick="closeMenu()">×</button></div>
  <div class="sm-nav">
    <button class="sm-item" onclick="location.href='home.html'">Home</button>
    <button class="sm-item" onclick="location.href='home.html'">Browse Listings</button>
    <div class="sm-div"></div>
    <button class="sm-item" onclick="authLogout()">Sign Out</button>
  </div>
  <div class="sm-foot"><span>© 2024 Home Finder</span></div>
</div>
<nav>
  <div class="nav-left"><button class="hbtn" onclick="openMenu()"><span></span><span></span><span></span></button></div>
  <div class="nav-center"><button class="logo" onclick="location.href='home.html'">Home Finder</button></div>
  <div class="nav-right">
    <div class="prof-wrap">
      <div class="prof-btn" id="prof-btn" style="background:#6b1a1a" onclick="toggleProf()">AU</div>
      <div class="prof-drop" id="prof-drop">
        <div class="pd-head"><div class="pd-name" id="pd-name">Admin User</div><div class="pd-role" style="color:#a03030">Administrator</div></div>
        <div id="pd-links"></div>
      </div>
    </div>
  </div>
</nav>
<main>
<div class="dl">
  <div class="sb2">
    <div class="sbu">
      <div class="sbav adm-av">AU</div>
      <div class="sbnm">Admin User</div>
      <div class="sbrl adm">Administrator</div>
    </div>
    <div class="sbmenu">
      <button class="sbi on" onclick="showTab('users')">Users</button>
      <button class="sbi" onclick="showTab('approvals')">Pending Approvals</button>
      <button class="sbi" onclick="showTab('listings')">Listings</button>
      <button class="sbi" onclick="showTab('appointments')">Appointments</button>
      <button class="sbi" onclick="showTab('profile')">Profile</button>
    </div>
  </div>
  <div class="dash-inner">
    <div class="dash-banner">
      <div class="dash-banner-txt">
        <h3>Athens Home Finder — Admin Panel</h3>
        <p>Manage users, listings and appointments across Athens</p>
      </div>
    </div>
    <div class="mp" id="mp"></div>
  </div>
</div>
<footer class="site-footer">
  <div class="footer-top" style="grid-template-columns:2fr 1fr 1fr">
    <div class="footer-brand"><div class="f-logo">Home Finder</div><p>Find your perfect home across Athens.</p></div>
    <div><div class="f-col-title">Navigation</div><ul class="f-links"><li><button onclick="location.href='home.html'">Home</button></li><li><button onclick="location.href='home.html'">Browse</button></li></ul></div>
    <div><div class="f-col-title">Company</div><ul class="f-links"><li><a href="#">About</a></li><li><a href="#">Contact</a></li></ul></div>
  </div>
  <div class="footer-bottom"><div class="f-copy">© 2024 Home Finder.</div><div class="f-legal"><a href="#">Privacy</a><a href="#">Terms</a></div></div>
</footer>
</main>

<script src="auth.js"></script>
<script>
const USER = getUser();

// build profile dropdown manually for admin
(function(){
  const pd = document.getElementById('pd-links');
  if(pd) pd.innerHTML = `
    <button class="pd-item" onclick="showTab('users')">Manage Users</button>
    <button class="pd-item" onclick="showTab('approvals')">Pending Approvals</button>
    <button class="pd-item" onclick="showTab('appointments')">All Appointments</button>
    <button class="pd-item" onclick="authLogout()">Sign Out</button>`;
})();

function getData(k,d){try{return JSON.parse(sessionStorage.getItem(k)||'null')||d;}catch{return d;}}
function setData(k,v){sessionStorage.setItem(k,JSON.stringify(v));}

let LS = getData('hf_ls',[]);
let APPTS = getData('hf_appts',[]);
let USERS = [
  {id:1,name:"James Thompson",  email:"james.t@email.com",    role:"buyer",  joined:"Mar 2024",status:"approved"},
  {id:2,name:"Sarah Mitchell",   email:"sarah.m@email.com",    role:"seller", joined:"Jan 2024",status:"approved"},
  {id:3,name:"Ana Rodriguez",    email:"ana.r@email.com",      role:"buyer",  joined:"Apr 2024",status:"approved"},
  {id:4,name:"Marco Verdi",      email:"marco.v@email.com",    role:"seller", joined:"Feb 2024",status:"approved"},
  {id:5,name:"Lisa Han",         email:"lisa.h@email.com",     role:"buyer",  joined:"Apr 2024",status:"approved"},
  {id:6,name:"Dimitris Alexiou", email:"d.alexiou@email.com",  role:"buyer",  joined:"Apr 2024",status:"approved"},
];
let PENDING = [
  {id:7,name:"John Davies",  email:"john.d@email.com",   joined:"Today"},
  {id:8,name:"Maria Costa",  email:"maria.c@email.com",  joined:"Today"},
];

let editingUserId = null;
let editingListingId = null;
let deletingType = null;
let deletingId = null;
let cancelingApptId = null;

/* ── TABS ── */
function showTab(t){
  document.querySelectorAll('.sbi').forEach((b,i)=>b.classList.toggle('on',['users','approvals','listings','appointments','profile'][i]===t));
  APPTS = getData('hf_appts',[]);
  LS = getData('hf_ls',[]);
  const mp = document.getElementById('mp');

  if(t==='users'){
    mp.innerHTML=`
      <div class="sh"><div><div class="stag">Admin</div><h2>Users</h2></div>
        <span style="font-size:13px;color:var(--mu)">${USERS.length} accounts</span></div>
      <div class="srow" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
        ${[[''+USERS.length,'Total Users'],[''+USERS.filter(u=>u.role==='seller').length,'Sellers'],[''+LS.length,'Listings']].map(([n,l])=>`<div class="sc2"><div class="sbig">${n}</div><div class="slb">${l}</div></div>`).join('')}
      </div>
      <table class="dt">
        <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead>
        <tbody>${USERS.map(u=>`<tr>
          <td style="font-weight:600">${u.name}</td>
          <td style="color:var(--mu);font-size:12px">${u.email}</td>
          <td><span class="badge b${u.role[0]}">${u.role}</span></td>
          <td><span class="pill ${u.status==='approved'?'confirmed':'pending'}">${u.status}</span></td>
          <td style="color:var(--mu);font-size:12px">${u.joined}</td>
          <td style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="bsm bsm-g" onclick="openEditUser(${u.id})">Edit</button>
            <button class="bsm bsm-o" style="color:#a03030;border-color:#f5c6c6" onclick="openDelete('user',${u.id},'${u.name}')">Remove</button>
          </td>
        </tr>`).join('')}</tbody>
      </table>`;

  } else if(t==='approvals'){
    mp.innerHTML=`
      <div class="sh"><div><div class="stag">Admin</div><h2>Pending Approvals</h2></div>
        <span style="font-size:13px;color:#856404">${PENDING.length} pending</span></div>
      <div class="infomsg" style="margin-bottom:16px">Buyers must be approved by an administrator before they can access the platform.</div>
      ${PENDING.length?`
      <table class="dt">
        <thead><tr><th>Name</th><th>Email</th><th>Registered</th><th>Actions</th></tr></thead>
        <tbody id="pending-tbody">${PENDING.map(u=>`<tr id="prow-${u.id}">
          <td style="font-weight:600">${u.name}</td>
          <td style="color:var(--mu);font-size:12px">${u.email}</td>
          <td style="color:var(--mu);font-size:12px">${u.joined}</td>
          <td style="display:flex;gap:6px">
            <button class="bsm bsm-g" onclick="approveUser(${u.id})">Approve</button>
            <button class="bsm bsm-o" style="color:#a03030;border-color:#f5c6c6" onclick="rejectUser(${u.id})">Reject</button>
          </td>
        </tr>`).join('')}</tbody>
      </table>`
      :'<p style="font-size:13px;color:var(--mu);padding:20px 0">No pending approvals at this time.</p>'}`;

  } else if(t==='listings'){
    mp.innerHTML=`
      <div class="sh"><div><div class="stag">Admin</div><h2>All Listings</h2></div>
        <button class="bsm bsm-g" style="padding:8px 18px;font-size:12px" onclick="om('nlMod')">+ New Listing</button></div>
      <div class="lg">${LS.map(l=>`
        <div class="lc">
          <div class="li-img" onclick="openL(${l.id})">${l.img?`<img src="${l.img}" alt="${l.address}" loading="lazy" referrerpolicy="no-referrer"/>`:'<span>Photo</span>'}<div class="li-badge">${l.type}</div></div>
          <div class="li-body">
            <div class="li-price">${l.price}</div>
            <div class="li-addr">${l.address}</div>
            <div class="li-meta"><span>${l.beds} Bed</span><span>${l.baths} Bath</span><span>${l.sqft}</span></div>
            <div class="li-acts">
              <button class="bsm bsm-g" onclick="openEditListing(${l.id})">Edit</button>
              <button class="bsm bsm-o" style="color:#a03030;border-color:#f5c6c6" onclick="openDelete('listing',${l.id},'${l.address}')">Delete</button>
            </div>
          </div>
        </div>`).join('')}</div>`;

  } else if(t==='appointments'){
    mp.innerHTML=`
      <div class="sh"><div><div class="stag">Admin</div><h2>All Appointments</h2></div></div>
      <div class="infomsg" style="margin-bottom:16px">You can cancel any appointment in an emergency. The buyer will be notified.</div>
      <table class="dt">
        <thead><tr><th>Buyer</th><th>Seller</th><th>Property</th><th>Date</th><th>Time</th><th>Status</th><th>Action</th></tr></thead>
        <tbody>${APPTS.length?APPTS.map(a=>`<tr>
          <td>${a.buyer}</td><td>${a.seller}</td><td>${a.property}</td>
          <td style="font-size:12px;color:var(--mu)">${a.date}</td>
          <td style="font-size:12px;color:var(--mu)">${a.time}</td>
          <td><span class="pill ${a.status}">${a.status}</span></td>
          <td>${a.status!=='cancelled'?`<button class="bsm bsm-o" style="font-size:10px;padding:4px 10px;color:#a03030;border-color:#f5c6c6" onclick="openCancelAppt(${a.id},'${a.property}')">Cancel</button>`:'<span style="font-size:11px;color:var(--li)">—</span>'}</td>
        </tr>`).join(''):'<tr><td colspan="7" style="text-align:center;color:var(--mu);padding:24px">No appointments yet.</td></tr>'}</tbody>
      </table>`;

  } else if(t==='profile'){
    mp.innerHTML=`
      <div class="sh"><div><div class="stag">Admin</div><h2>Profile</h2></div></div>
      <div style="max-width:400px">
        <div class="fg"><label class="fl">Name</label><input type="text" class="fi" id="ap-name" value="Admin User"/></div>
        <div class="fg"><label class="fl">Email</label><input type="email" class="fi" id="ap-email" value="admin@homefinder.com"/></div>
        <div class="fg"><label class="fl">New Password</label><input type="password" class="fi" id="ap-pw" placeholder="Leave blank to keep current"/></div>
        <button class="bsm bsm-g" style="padding:10px 24px;font-size:12px;margin-top:8px" onclick="saveAdminProfile()">Save Changes</button>
      </div>`;
  }
}

/* ── USER EDIT ── */
function openEditUser(id){
  const u = USERS.find(x=>x.id===id);
  if(!u) return;
  editingUserId = id;
  document.getElementById('eu-name').value   = u.name;
  document.getElementById('eu-email').value  = u.email;
  document.getElementById('eu-role').value   = u.role;
  document.getElementById('eu-status').value = u.status;
  om('editUserMod');
}
function saveUser(){
  const u = USERS.find(x=>x.id===editingUserId);
  if(u){
    u.name   = document.getElementById('eu-name').value.trim()   || u.name;
    u.email  = document.getElementById('eu-email').value.trim()  || u.email;
    u.role   = document.getElementById('eu-role').value;
    u.status = document.getElementById('eu-status').value;
  }
  cm('editUserMod');
  toast('User updated successfully.');
  showTab('users');
}

/* ── LISTING EDIT ── */
function openEditListing(id){
  const l = LS.find(x=>x.id===id);
  if(!l) return;
  editingListingId = id;
  document.getElementById('el-price').value = l.raw;
  document.getElementById('el-type').value  = l.type;
  document.getElementById('el-addr').value  = l.address;
  document.getElementById('el-beds').value  = l.beds;
  document.getElementById('el-baths').value = l.baths;
  document.getElementById('el-desc').value  = l.desc;
  om('editListingMod');
}
function saveListing(){
  const l = LS.find(x=>x.id===editingListingId);
  if(l){
    const newPrice = parseInt(document.getElementById('el-price').value);
    l.raw     = newPrice || l.raw;
    l.price   = '€' + (l.raw).toLocaleString();
    l.type    = document.getElementById('el-type').value;
    l.address = document.getElementById('el-addr').value.trim() || l.address;
    l.beds    = parseInt(document.getElementById('el-beds').value)  || l.beds;
    l.baths   = parseInt(document.getElementById('el-baths').value) || l.baths;
    l.desc    = document.getElementById('el-desc').value.trim()  || l.desc;
    setData('hf_ls', LS);
  }
  cm('editListingMod');
  toast('Listing updated successfully.');
  showTab('listings');
}

/* ── ADD LISTING ── */
function addListing(){
  const addr  = document.getElementById('nl-addr').value.trim();
  const price = parseInt(document.getElementById('nl-price').value);
  if(!addr || !price){ toast('Please fill in address and price.'); return; }
  const newL = {
    id: Date.now(), price:'€'+price.toLocaleString(), raw:price,
    address:addr, city:addr.split(',')[0].trim(),
    type: document.getElementById('nl-type').value,
    beds: parseInt(document.getElementById('nl-beds').value)||3,
    baths:parseInt(document.getElementById('nl-baths').value)||1,
    sqft: document.getElementById('nl-sqft').value||'100 m²',
    desc: document.getElementById('nl-desc').value||'Property in Athens.',
    seller:'Admin User', si:'AU',
    img:'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&h=400&fit=crop&q=80'
  };
  LS.push(newL);
  setData('hf_ls', LS);
  cm('nlMod');
  toast('New listing added successfully!');
  showTab('listings');
}

/* ── DELETE ── */
function openDelete(type, id, name){
  deletingType = type;
  deletingId   = id;
  document.getElementById('del-msg').textContent = `Delete "${name}"? This cannot be undone.`;
  om('confirmDelMod');
}
function confirmDelete(){
  if(deletingType==='user'){
    USERS = USERS.filter(u=>u.id!==deletingId);
    toast('User removed.');
    cm('confirmDelMod'); showTab('users');
  } else if(deletingType==='listing'){
    LS = LS.filter(l=>l.id!==deletingId);
    setData('hf_ls', LS);
    toast('Listing deleted.');
    cm('confirmDelMod'); showTab('listings');
  }
}

/* ── APPROVALS ── */
function approveUser(id){
  const u = PENDING.find(x=>x.id===id);
  if(u){
    USERS.push({id:u.id,name:u.name,email:u.email,role:'buyer',joined:'Today',status:'approved'});
    PENDING = PENDING.filter(x=>x.id!==id);
    toast(u.name+' approved and added to users.');
    showTab('approvals');
  }
}
function rejectUser(id){
  const u = PENDING.find(x=>x.id===id);
  if(u){ PENDING = PENDING.filter(x=>x.id!==id); toast(u.name+' rejected.'); showTab('approvals'); }
}

/* ── CANCEL APPOINTMENT ── */
function openCancelAppt(id, prop){
  cancelingApptId = id;
  document.getElementById('ca-msg').textContent = `Cancel the appointment for "${prop}"? The buyer will be notified.`;
  om('cancelApptMod');
}
function doAdminCancel(){
  APPTS = getData('hf_appts',[]);
  const a = APPTS.find(x=>x.id===cancelingApptId);
  if(a) a.status='cancelled';
  setData('hf_appts', APPTS);
  cm('cancelApptMod');
  toast('Appointment cancelled by admin.');
  showTab('appointments');
}

/* ── PROFILE ── */
function saveAdminProfile(){
  const name = document.getElementById('ap-name').value.trim();
  const pw   = document.getElementById('ap-pw').value;
  if(name && USER){ USER.name=name; sessionStorage.setItem('hf_user',JSON.stringify(USER)); }
  toast(pw ? 'Profile and password updated.' : 'Profile saved.');
}

function openL(id){ sessionStorage.setItem('hf_cur',id); location.href='home.html'; }
function om(id){ document.getElementById(id).classList.add('on'); }
function cm(id){ document.getElementById(id).classList.remove('on'); }
document.querySelectorAll('.ov').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('on');}));
function openMenu(){ document.getElementById('mOv').classList.add('on'); document.getElementById('sMenu').classList.add('on'); }
function closeMenu(){ document.getElementById('mOv').classList.remove('on'); document.getElementById('sMenu').classList.remove('on'); }
function toggleProf(){ document.getElementById('prof-drop').classList.toggle('on'); }
document.addEventListener('click',e=>{ if(!e.target.closest('.prof-wrap')) document.getElementById('prof-drop').classList.remove('on'); });
function toast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('on'); clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove('on'),3200); }
showTab('users');
</script>
