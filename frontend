function adminCancelAppt(id){const a=APPTS.find(x=>x.id===id);if(a)a.status='cancelled';toast('Appointment cancelled by admin.');atab('appointments');}

/* CHAT */
function send(){
  const inp=document.getElementById('cinp');const txt=inp.value.trim();if(!txt)return;
  const box=document.getElementById('cms');const t=new Date();const ts=t.getHours()+':'+String(t.getMinutes()).padStart(2,'0');
  box.innerHTML+=`<div class="cmsg me"><div class="bub me">${esc(txt)}</div><div class="mt" style="text-align:right">${ts}</div></div>`;
  inp.value='';box.scrollTop=box.scrollHeight;
  setTimeout(()=>{const rs=["Thanks, I'll get back to you shortly.","Sounds good!","Looking forward to the viewing.","Feel free to call anytime."];const t2=new Date();box.innerHTML+=`<div class="cmsg"><div class="bub them">${rs[Math.floor(Math.random()*rs.length)]}</div><div class="mt">${t2.getHours()}:${String(t2.getMinutes()).padStart(2,'0')}</div></div>`;box.scrollTop=box.scrollHeight;},1200);
}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

/* MODALS */
function om(id){document.getElementById(id).classList.add('on');}
function cm(id){document.getElementById(id).classList.remove('on');}
function addListing(){cm('nlMod');uploadedFiles=[];document.getElementById('fileList').innerHTML='';toast('Listing added with '+(uploadedFiles.length||0)+' files.');}
document.querySelectorAll('.ov').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)this.classList.remove('on');}));

/* TOAST */
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),3200);}

renderFeat();
</script>
