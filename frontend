/* BOOKING CALENDAR */
function buildCalendar(containerId, inputId){
  const c=document.getElementById(containerId);
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  let html=days.map(d=>`<div class="cal-head">${d}</div>`).join('');
  for(let d=7;d<=13;d++){
    const booked=BOOKED_DAYS.includes(d);
    const past=d<7;
    let cls='cal-day'+(booked?' booked':past?' past':'');
    const evt=APPTS.find(a=>parseInt(a.date.split(' ')[1])===d);
    html+=`<div class="${cls}" onclick="selectDay(${d},'${inputId}',this)">
      <div class="cal-day-num">${d}</div>
      ${booked?`<div class="cal-booked-lbl">Booked</div>`:evt?`<div class="cal-event">${evt.time}</div>`:''}
    </div>`;
  }
  c.innerHTML=html;
}
function selectDay(day,inputId,el){
  if(el.classList.contains('booked')||el.classList.contains('past')){toast('This date is already booked. Please select another.');return;}
  document.querySelectorAll('.cal-day').forEach(d=>d.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById(inputId).value='Apr '+day+', 2024';
  selectedBookDay=day;
}
function openBookModal(addr){
  document.getElementById('bk-txt').textContent='Select an available date for: '+addr;
  buildCalendar('book-cal','sel-date');
  selectedBookDay=null;
  document.getElementById('sel-date').value='';
  om('bkMod');
}
function confirmBook(){
  if(!selectedBookDay){toast('Please select a date first.');return;}
  BOOKED_DAYS.push(selectedBookDay);
  const time=document.getElementById('sel-time').value;
  const name=document.getElementById('bk-name').value||'Buyer';
